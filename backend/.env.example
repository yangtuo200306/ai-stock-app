# ============================================
# 【必填】LLM 配置（火山方舟）
# ============================================
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=ep-your-endpoint-id-here

# ============================================
# 【生产环境建议改为绝对路径】数据库路径
# ============================================
# 开发环境（相对于 backend/ 目录）：
# DATABASE_PATH=ai_stock.db
# 生产环境建议：
# DATABASE_PATH=/opt/ai-stock-app/data/ai_stock.db

# ============================================
# 【生产环境必填】CORS 允许的来源（逗号分隔）
# ============================================
# 开发环境：
# CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
# 生产环境改为手机 App 实际访问的地址

# ============================================
# 【可选】行情数据
# ============================================
# QUOTE_CACHE_TTL_SECONDS=60
# PRIMARY_MARKET_SOURCE=efinance
# FALLBACK_MARKET_SOURCE=sina

# ============================================
# 【生产环境建议改为绝对路径】日志
# ============================================
# LOG_DIR=logs
# LOG_LEVEL=INFO
